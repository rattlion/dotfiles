{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "footer": {
      "items": [
        "sandbox",
        "model-name",
        "quota",
        "context-used",
        "memory-usage",
        "token-count"
      ]
    },
    "showLineNumbers": false,
    "terminalBuffer": false
  },
  "general": {
    "vimMode": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    },
    "preferredEditor": "neovim",
    "enableAutoUpdate": true,
    "enableNotifications": true
  }
}